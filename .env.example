# URL de base de l'API Moodle (ex: https://moodle.tonsite.fr/webservice/rest/server.php)
MOODLE_URL=https://TON_MOODLE/webservice/rest/server.php

# Token généré dans Moodle (à ne jamais commiter !)
MOODLE_TOKEN=ton_token_ultra_secret

# Port pour le serveur MCP (optionnel)
PORT=3000

# Token requis pour le serveur HTTP (claude.ai connector). Générer avec :
#   openssl rand -hex 32
# Ne jamais commiter la vraie valeur (voir .env, ignoré par git).
MCP_ACCESS_TOKEN=remplace_moi_par_un_token_genere
